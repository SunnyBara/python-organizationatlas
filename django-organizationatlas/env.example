# Environment variables for django-organizationatlas
# Copy this file to .env and fill in your values

# Django settings
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (if not using SQLite)
# DATABASE_URL=postgresql://user:password@localhost/dbname

# OrganizationAtlas Backends
# Format: ORGANIZATIONATLAS_{BACKEND_NAME}_{KEY}
# Example for INSEE:
ORGANIZATIONATLAS_INSEE_API_KEY=your-insee-api-key-here
# ORGANIZATIONATLAS_INSEE_BASE_URL=

# Other backends (see python-organizationatlas/env.example for full list)
# ORGANIZATIONATLAS_ENTDATAGOUV_BASE_URL=
# ORGANIZATIONATLAS_PAPPERS_API_KEY=

