# Environment variables for python-organizationatlas
# Copy this file to .env and fill in your values
#
# Format: ORGANIZATIONATLAS_{BACKEND_NAME}_{KEY}
# Priority: config dict > environment variable > default value

# BODACC
# ORGANIZATIONATLAS_BODACC_API_KEY=
# ORGANIZATIONATLAS_BODACC_BASE_URL=

# EntDataGouv (data.gouv.fr)
# ORGANIZATIONATLAS_ENTDATAGOUV_BASE_URL=

# Infogreffe
# ORGANIZATIONATLAS_INFOGREFFE_API_KEY=
# ORGANIZATIONATLAS_INFOGREFFE_USERNAME=
# ORGANIZATIONATLAS_INFOGREFFE_PASSWORD=
# ORGANIZATIONATLAS_INFOGREFFE_BASE_URL=

# INPI
# ORGANIZATIONATLAS_INPI_API_KEY=
# ORGANIZATIONATLAS_INPI_USERNAME=
# ORGANIZATIONATLAS_INPI_PASSWORD=
# ORGANIZATIONATLAS_INPI_BASE_URL=

# INSEE
# ORGANIZATIONATLAS_INSEE_API_KEY=
# ORGANIZATIONATLAS_INSEE_BASE_URL=

# Huwise
# ORGANIZATIONATLAS_HUWISE_DATASET_ID=
# ORGANIZATIONATLAS_HUWISE_BASE_URL=

# Pappers
# ORGANIZATIONATLAS_PAPPERS_API_KEY=
# ORGANIZATIONATLAS_PAPPERS_BASE_URL=

# Pharow
# ORGANIZATIONATLAS_PHAROW_API_KEY=
# ORGANIZATIONATLAS_PHAROW_API_SECRET=
# ORGANIZATIONATLAS_PHAROW_BASE_URL=

# SocieteCom
# ORGANIZATIONATLAS_SOCIETECOM_API_KEY=
# ORGANIZATIONATLAS_SOCIETECOM_API_SECRET=
# ORGANIZATIONATLAS_SOCIETECOM_BASE_URL=

